generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USER & REFERRALS ──────────────────────────────────────────

model User {
  id            String  @id @default(uuid())
  telegramId    String  @unique
  username      String?
  firstName     String?
  lastName      String?
  clubName      String?
  clubIcon      String?
  photoUrl      String?
  coins         Int     @default(1000)
  reputation    Int     @default(0) // legacy
  points        Int     @default(0) // Division/Rank points
  level         Int     @default(1)
  experience    Int     @default(0)
  isAdmin       Boolean @default(false)
  scoutingLevel Int     @default(1)
  scoutingExp   Int     @default(0)
  referralCode  String  @unique
  referredById  String?

  // При удалении пригласившего, связь зануляется (SetNull), чтобы приглашенный не удалился
  referredBy User?  @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals  User[] @relation("UserReferrals")

  dailyMatchesPlayed  Int      @default(0)
  dailyMatchesResetAt DateTime @default(now())

  energy          Int      @default(10)
  energyUpdatedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teams           Team[]
  referralsMade   Referral[]     @relation("ReferralInviter")
  referralsUsed   Referral[]     @relation("ReferralInvitee")
  scouts          Scout[]
  trainings       Training[]
  matchesAsHome      Match[]             @relation("HomeUser")
  matchesAsAway      Match[]             @relation("AwayUser")
  invitesSent        MatchInvite[]       @relation("InviteSender")
  invitesReceived    MatchInvite[]       @relation("InviteRecipient")
  matchmakingEntries MatchmakingQueue[]
  draftSessions      DraftSession[]
  eventDrafts     EventDraft[]
  userTasks       UserTask[]
  lessorContracts RentContract[] @relation("LessorContracts")
  renterContracts RentContract[] @relation("RenterContracts")
  economyLogs     EconomyLog[]
  matchStreak     MatchStreak?
}

model MatchStreak {
  id        String @id @default(uuid())
  userId    String @unique
  streak    Int    @default(0)
  bestStreak Int   @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Referral {
  id        String @id @default(uuid())
  inviterId String
  inviteeId String
  reward    Int    @default(500)

  // Если удаляется один из участников рефералки — запись лога реферала стирается
  inviter   User     @relation("ReferralInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee   User     @relation("ReferralInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([inviterId, inviteeId])
}

// ─── PLAYERS ────────────────────────────────────────────────────

enum Position {
  GK
  CB
  LB
  RB
  CDM
  CM
  CAM
  LW
  RW
  ST
  CF
}

enum PlayerStyle {
  SPEEDY
  POWERFUL
  TECHNICAL
  ATTACKING
  DEFENSIVE
  POSITIONAL
}

enum PlayerRole {
  GOALKEEPER
  DEFENDER
  MIDFIELDER
  FORWARD
}

model Player {
  id            String      @id @default(uuid())
  name          String
  surname       String?     @default("")
  overallRating Int         @default(50)
  position      Position
  role          PlayerRole
  style         PlayerStyle

  pace           Int @default(50)
  paceBonus      Int @default(0)
  shooting       Int @default(50)
  shootingBonus  Int @default(0)
  passing        Int @default(50)
  passingBonus   Int @default(0)
  dribbling      Int @default(50)
  dribblingBonus Int @default(0)
  defending      Int @default(50)
  defendingBonus Int @default(0)
  physical       Int @default(50)
  physicalBonus  Int @default(0)
  goalkeeping    Int @default(50)

  formValue Float @default(1.0)
  fatigue   Int   @default(0)

  country      String @default("RU")
  potentialMin Int    @default(80)
  potentialMax Int    @default(90)
  heightCm     Int    @default(180)
  weightKg     Int    @default(75)
  foot         String @default("Right")
  skillMoves   Int    @default(3)
  weakFoot     Int    @default(3)

  injuryType   String?
  injuryEndsAt DateTime?

  isNft         Boolean   @default(false)
  mintedAt      DateTime?
  tokenId       String?
  nftAddress    String?
  matchesPlayed Int       @default(0)
  mintingStatus String    @default("none") // "none" | "minting_process" | "converted_to_nft"
  lockedAt      DateTime?

  age         Int    @default(22)
  nationality String @default("Unknown")
  clubId      Int?   @default(0)
  club        String @default("Free Agent")

  leagueId         Int? @default(0)
  leagueDivisionId Int? @default(0)

  trainingLevel              Int @default(1)
  trainingLevelMax           Int @default(25)
  trainingExperience         Int @default(0)
  trainingExperienceRequired Int @default(200)

  face       String? @default("face_1")
  hairStyle  String? @default("short")
  hairColor  String? @default("black")
  skinColor  String? @default("light")
  beardStyle String? @default("none")
  beardColor String? @default("none")
  emotion    String? @default("neutral")
  rarity     String? @default("common")
  imageUrl   String?

  ownerId   String?
  isOnRent  Boolean  @default(false)
  rentPrice Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teamPlayers   TeamPlayer[]
  trainings     Training[]
  scoutResults  ScoutResult[]
  draftOptions  DraftOption[]
  matchEvents   MatchEvent[]
  rent          PlayerRent?
  rentContracts RentContract[]
}

model PlayerRent {
  id       String @id @default(uuid())
  playerId String @unique
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  isRented   Boolean @default(false)
  rentedById String?

  priceTon  Float? @default(0)
  priceCoin Int?   @default(0)

  durationOptions Json?
  conditions      Json?

  startedAt DateTime?
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── TEAMS ──────────────────────────────────────────────────────

model Team {
  id        String  @id @default(uuid())
  name      String
  rating    Float   @default(0)
  formation String  @default("4-4-2")
  userId    String
  isEvent   Boolean @default(false)
  isBot     Boolean @default(false)
  eventId   String?

  // Удалили юзера -> удалилась его команда
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  players     TeamPlayer[]
  homeMatches Match[]      @relation("HomeTeam")
  awayMatches Match[]      @relation("AwayTeam")

  seasonStandings SeasonStanding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamPlayer {
  id                  String  @id @default(uuid())
  teamId              String
  playerId            String
  isStarter           Boolean @default(false)
  positionInFormation String?

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  // Если удаляется игрок (Player), он также убирается из состава команды
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([teamId, playerId])
}

// ─── DRAFT ──────────────────────────────────────────────────────

enum DraftStatus {
  IN_PROGRESS
  COMPLETED
}

enum DraftStep {
  GK
  DEF
  MID
  FWD
  RESERVE
  DONE
}

model DraftSession {
  id     String      @id @default(uuid())
  userId String
  status DraftStatus @default(IN_PROGRESS)
  step   DraftStep   @default(GK)
  teamId String?

  // Удалили юзера -> удалилась сессия драфта
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  options DraftOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DraftOption {
  id             String    @id @default(uuid())
  draftSessionId String
  playerId       String
  step           DraftStep
  isPicked       Boolean   @default(false)

  draftSession DraftSession @relation(fields: [draftSessionId], references: [id], onDelete: Cascade)
  player       Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

// ─── MATCHES ────────────────────────────────────────────────────

enum MatchType {
  FRIENDLY
  CHALLENGE
  SEASON
  EVENT
}

enum MatchStatus {
  READY
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ABANDONED
}

enum MatchInviteType {
  FRIEND
  OPEN
}

enum MatchInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  EXPIRED
}

enum MatchmakingStatus {
  SEARCHING
  MATCHED
  CANCELLED
  EXPIRED
}

enum PressingType {
  SOFT
  MEDIUM
  INTENSIVE
}

model Match {
  id     String      @id @default(uuid())
  type   MatchType   @default(FRIENDLY)
  status MatchStatus @default(READY)

  homeUserId String?
  awayUserId String?
  homeTeamId String
  awayTeamId String?
  isBot      Boolean @default(false)

  homeScore Int?
  awayScore Int?
  seed      String?
  overtime  Boolean @default(false)

  homePressingType PressingType @default(MEDIUM)
  awayPressingType PressingType @default(MEDIUM)

  homeCoins Int @default(0)
  awayCoins Int @default(0)
  homeExp   Int @default(0)
  awayExp   Int @default(0)

  currentMinute Int       @default(0)
  startedAt     DateTime?
  finishedAt    DateTime?

  homeReady Boolean @default(false)
  awayReady Boolean @default(false)

  inviteId String? @unique
  invite   MatchInvite? @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  seasonId String?
  eventId  String?

  homeUser User? @relation("HomeUser", fields: [homeUserId], references: [id], onDelete: SetNull)
  awayUser User? @relation("AwayUser", fields: [awayUserId], references: [id], onDelete: SetNull)

  homeTeam Team    @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam Team?   @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)
  season   Season? @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  event    Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  events MatchEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, type])
  @@index([homeUserId, status])
  @@index([awayUserId, status])
}

model MatchInvite {
  id          String            @id @default(uuid())
  type        MatchInviteType
  status      MatchInviteStatus @default(PENDING)
  senderId    String
  recipientId String?
  senderTeamId String
  expiresAt   DateTime
  acceptedAt  DateTime?
  declinedAt  DateTime?

  sender    User  @relation("InviteSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User? @relation("InviteRecipient", fields: [recipientId], references: [id], onDelete: SetNull)
  match     Match?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([senderId, recipientId, status])
  @@index([status, expiresAt])
  @@index([type, status])
}

model MatchmakingQueue {
  id             String            @id @default(uuid())
  userId         String
  teamId         String
  pointsSnapshot Int
  status         MatchmakingStatus @default(SEARCHING)
  matchId        String?
  expiresAt      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, pointsSnapshot])
  @@index([userId, status])
  @@index([status, expiresAt])
}

model MatchEvent {
  id            String  @id @default(uuid())
  matchId       String
  minute        Int
  type          String
  team          String
  playerId      String?
  playerName    String?
  playerOutId   String?
  playerOutName String?
  description   String

  match  Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player? @relation(fields: [playerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

// ─── SEASONS & DIVISIONS ────────────────────────────────────────

enum SeasonStatus {
  UPCOMING
  ACTIVE
  PLAYOFFS
  COMPLETED
}

model Season {
  id        String       @id @default(uuid())
  name      String
  division  Int          @default(1)
  status    SeasonStatus @default(UPCOMING)
  startDate DateTime
  endDate   DateTime

  matches   Match[]
  standings SeasonStanding[]

  createdAt DateTime @default(now())

  @@index([status])
}

model SeasonStanding {
  id       String @id @default(uuid())
  seasonId String
  teamId   String

  played       Int @default(0)
  wins         Int @default(0)
  draws        Int @default(0)
  losses       Int @default(0)
  goalsFor     Int @default(0)
  goalsAgainst Int @default(0)
  points       Int @default(0)

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([seasonId, teamId])
  @@index([seasonId, points(sort: Desc), goalsFor(sort: Desc)])
}

// ─── EVENTS ─────────────────────────────────────────────────────

enum EventType {
  WORLD_CUP
  EURO
  COPA_AMERICA
  CHAMPIONS_LEAGUE
}

enum EventStatus {
  UPCOMING
  DRAFT_PHASE
  ACTIVE
  COMPLETED
}

model Event {
  id        String      @id @default(uuid())
  name      String
  type      EventType
  status    EventStatus @default(UPCOMING)
  startDate DateTime
  endDate   DateTime
  rules     Json?

  teams   Team[]
  matches Match[]
  drafts  EventDraft[]

  createdAt DateTime @default(now())
}

model EventDraft {
  id      String      @id @default(uuid())
  eventId String
  userId  String
  status  DraftStatus @default(IN_PROGRESS)
  step    DraftStep   @default(GK)
  teamId  String?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── SCOUTING ───────────────────────────────────────────────────

enum ScoutStatus {
  PENDING
  ACTIVE
  COMPLETED
  COLLECTED
}

model Scout {
  id           String      @id @default(uuid())
  userId       String
  region       String
  ageMin       Int         @default(16)
  ageMax       Int         @default(35)
  targetRole   PlayerRole?
  status       ScoutStatus @default(ACTIVE)
  endsAt       DateTime
  tier         String      @default("COMMON")
  cost         Int         @default(0)
  costCurrency String      @default("COIN")

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  results ScoutResult[]

  createdAt DateTime @default(now())
}

model ScoutResult {
  id       String @id @default(uuid())
  scoutId  String
  playerId String

  scout  Scout  @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─── TASKS ──────────────────────────────────────────────────────

enum TaskType {
  SEASON
  DAILY
  INTRO
}

enum TaskObjective {
  GOALS
  WINS
  MATCHES
  CLEAN_SHEETS
  REFERRALS
  SOCIAL_JOIN
  EXTERNAL_LINK
}

model Task {
  id          String        @id @default(uuid())
  title       String        @default("")
  description String?
  titleRu     String        @default("")
  descriptionRu String?
  titleEn     String        @default("")
  descriptionEn String?
  type        TaskType
  objective   TaskObjective @default(MATCHES)
  reward      Int
  goal        Int
  icon        String?
  link        String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  userTasks   UserTask[]
}

model UserTask {
  id        String    @id @default(uuid())
  userId    String
  taskId    String
  progress  Int       @default(0)
  claimed   Boolean   @default(false)
  claimedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
}

// ─── TRAINING ───────────────────────────────────────────────────

enum TrainingStatus {
  IN_PROGRESS
  COMPLETED
}

model Training {
  id       String         @id @default(uuid())
  userId   String
  playerId String
  stat     String
  boost    Int            @default(1)
  cost     Int
  status   TrainingStatus @default(IN_PROGRESS)
  endsAt   DateTime

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─── RENTALS ──────────────────────────────────────────────────
enum RentStatus {
  ACTIVE
  FINISHED
}

model RentContract {
  id        String     @id @default(uuid())
  playerId  String
  lessorId  String
  renterId  String
  price     Int
  startDate DateTime   @default(now())
  endDate   DateTime
  status    RentStatus @default(ACTIVE)

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  lessor User   @relation("LessorContracts", fields: [lessorId], references: [id], onDelete: Cascade)
  renter User   @relation("RenterContracts", fields: [renterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, endDate])
}

// ─── ECONOMY ANALYTICS ──────────────────────────────────────────

enum EconomySource {
  RENTAL_FEE
  MATCH_REWARD
  TASK_REWARD
  SCOUTING_COST
  TRAINING_COST
  REFERRAL_REWARD
  ADMIN_ADJUSTMENT
}

model EconomyLog {
  id       String        @id @default(uuid())
  userId   String
  amount   Int
  currency String        @default("COIN")
  source   EconomySource
  details  Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([source, createdAt])
}
