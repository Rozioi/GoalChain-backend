{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "declaration": true,
    },
    "include": ["src/**/*"],
    "exclude": [
        "node_modules",
        "dist",
        "prisma.config.ts",
        "src/ws/client.example.ts",
    ],
}
