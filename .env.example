# =====================
# Сервер
# =====================
DATABASE_URL=postgresql://user:password@localhost:5432/goalchain
JWT_SECRET=your-secret-key-change-me
PORT=3000
NODE_ENV=development

# Telegram Mini App
BOT_TOKEN=your-telegram-bot-token
WEBAPP_URL=https://t.me/your_bot/your_app

# TON
TON_COLLECTION_ADDRESS=EQC...
TON_RPC_ENDPOINT=https://toncenter.com/api/v2/jsonRPC
TON_API_KEY=your-ton-api-key
TON_PAYMENT_ADDRESS=EQC...  # Адрес для оплаты Master скаута
NETWORK=mainnet              # mainnet | testnet

# Together AI (генерация картинок игроков)
TOGETHER_API_KEY=your-together-api-key

# Redis (опционально, для WebSocket multi-instance)
REDIS_URL=

# CORS
CORS_ORIGIN=*
